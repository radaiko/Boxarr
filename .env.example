# ── Boxarr environment (BOXARR_* via envconfig.Process("boxarr")) ──
# NOTHING here is required: Boxarr boots with zero env and all connections,
# paths, and tuning are configured from the Settings page in the UI (persisted
# in the DB). Env vars below are an OPTIONAL seed/override — handy for pre-seeding
# a container. DB-set (UI) values always win and apply live without a restart.
# Slice vars are COMMA-SEPARATED with NO spaces. Secrets are never logged.

# ── Bootstrap-only (cannot come from the DB, since they're needed to open it /
#    bind the port). All optional with sane defaults. ──
# BOXARR_DATABASE_PATH=/config/boxarr.db
# BOXARR_LISTEN_ADDR=:8080
# BOXARR_LOG_LEVEL=info

# ── Optional seed for connections (or just set them in the UI) ──
# BOXARR_TORBOX_API_TOKEN=your-torbox-token
# BOXARR_PROWLARR_URL=http://prowlarr:9696
# BOXARR_PROWLARR_API_KEY=your-prowlarr-api-key
# BOXARR_TMDB_API_KEY=your-tmdb-read-access-token

# ── WebDAV mount (required) — same absolute path in every container (Plex incl.) ──
# BOXARR_WEBDAV_MOUNT_ROOT=/mnt/torbox
# BOXARR_WEBDAV_USENET_SUBPATH=
# Leave empty unless torrents surface under a separate subpath (runtime-verify, 00 §19.5).
# BOXARR_WEBDAV_TORRENT_SUBPATH=

# ── Library roots (Plex-standard; share the WebDAV mount's filesystem) ──
# BOXARR_MOVIE_LIBRARY_ROOT=/data/movies
# BOXARR_TV_LIBRARY_ROOT=/data/tv
# Transitional (reused worker needs it; removed in Phase 1).
# BOXARR_SYMLINK_ROOT=/data/_incoming

# ── Storage / runtime ──
# BOXARR_DATABASE_PATH=/config/boxarr.db
# BOXARR_LISTEN_ADDR=:8080
# BOXARR_LOG_LEVEL=info
# BOXARR_POLL_INTERVAL=1m
# BOXARR_RECONCILE_INTERVAL=15m
# BOXARR_METADATA_REFRESH_INTERVAL=24h
# BOXARR_SEARCH_INTERVAL=6h
# Phase 5 automation (optional, default off): scheduled metadata refresh +
# auto-search of monitored, still-missing items. Manual search works regardless.
# BOXARR_AUTOMATION_ENABLED=false

# ── App auth (empty + loopback request = allowed; set to require X-Api-Key) ──
# BOXARR_API_KEY=

# ── TVDB (optional — scene/absolute episode ordering) ──
# BOXARR_TVDB_API_KEY=
# BOXARR_TVDB_PIN=

# ── Plex (optional — fast partial scans after import) ──
# BOXARR_PLEX_URL=
# BOXARR_PLEX_TOKEN=
# BOXARR_PLEX_MOVIE_SECTION=
# BOXARR_PLEX_TV_SECTION=

# ── Seerr inbound emulation (optional — Overseerr/Jellyseerr) ──
# BOXARR_SEERR_API_KEYS=

# ── TorBox WebDAV force-refresh (optional — set BOTH to enable) ──
# BOXARR_TORBOX_WEBDAV_USER=
# BOXARR_TORBOX_WEBDAV_PASS=

# ── Selection score (FR-SR-5; full knob list in docs/specs/06 §3) ──
# BOXARR_SELECT_PREFERRED_RESOLUTIONS=2160p,1080p,720p
# BOXARR_SELECT_PREFERRED_QUALITIES=WEB-DL,BluRay,WEBRip,HDTV
# BOXARR_SELECT_MIN_SEEDERS=1
# BOXARR_SELECT_REQUIRE_CACHED=false
# BOXARR_SELECT_BLOCKED_KEYWORDS=

# ── TorBox limits (FR-LIM-2/3) ──
# 0 = derive active-slot limit from the TorBox plan; >0 = hard cap.
# BOXARR_MAX_ACTIVE_DOWNLOADS=0
# BOXARR_MAX_CREATE_PER_HOUR=60
# BOXARR_MAX_TORRENT_PER_MIN=300

# ── Auto-heal (optional — HEAL_LIBRARY_ROOTS required when enabled) ──
# BOXARR_HEAL_ENABLED=false
# BOXARR_HEAL_LIBRARY_ROOTS=/data/tv,/data/movies
# BOXARR_HEAL_PROWLARR_FALLBACK=true
